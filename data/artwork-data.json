      "properties": {
        "title": "Aurora Aksnes - The Seed",
        "description": "The Norwegian singer Aurora released a song 'The Seed' addressing humanity's greed: 'When the last tree has fallen, and the rivers are poisoned, you cannot eat money, oh no.' She actively supports environmental movements and human rights, including an Arctic concert in collaboration with Greenpeace to protect the seas and the climate.",
        "artist": "Aurora Aksnes",
        "type": "Performance",
        "location": "Norway",
        "year": 2019,
        "tags": {
          "topic": ["Climate Activism", "Environmentalism"],
          "artform": ["Music", "Performance"]
        }
      }
    },
